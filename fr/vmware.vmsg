msg.busmem.tooLargePMEM = "La machine virtuelle est configurée pour trop de mémoire.|0ALa mémoire principale %1$s et la PMEM %2$s dépassent le maximum autorisé de %3$s|0A"
msg.cdrom.beyondEndOfImage = "Le client a tenté de lire au-delà de la fin d'une image disque. L'image à %1$s peut être incomplète ou endommagée.|0A"
msg.cdrom.connectDir = "Impossible de connecter le CD-ROM au back-end '%1$s'. Impossible d'utiliser un répertoire en tant qu'image de CD-ROM.|0A"
msg.cdrom.ejectFail = "Le lecteur de CD-ROM n'a pas pu éjecter le disque.|0AErreur : %1$s.|0AAssurez-vous que le CD-ROM n'est pas utilisé par l'hôte ni associé à d'autres machines virtuelles.|0A"
msg.cdrom.lockfail = "Le CD-ROM est lu par un autre processus, soit AutoRun est activé, soit le CD-ROM est ouvert dans l'Explorateur Windows. Ceci peut entraîner des problèmes lors de la lecture du CD-ROM dans la machine virtuelle. Arrêtez le processus qui lit le CD-ROM avant d'autoriser la machine virtuelle à lire le CD-ROM.|0APour le faire maintenant, sélectionnez %1$s. Pour le faire plus tard, sélectionnez %2$s, puis reconnectez le CD-ROM quand vous serez prêt. Vous pouvez également ignorer cette erreur et toutes les erreurs futures similaires en sélectionnant %3$s.|0A"
msg.cdrom.notImplemented = "La machine virtuelle a envoyé une commande de CD-ROM non gérée dans le cadre de l'émulation héritée.|0ALe paquet de commande était :  %1$s|0AIl ne s'agit pas d'une erreur grave, mais elle peut provoquer une erreur dans l'application qui essaie d'accéder au CD-ROM. Essayez d'exécuter cette machine virtuelle sans émulation héritée."
msg.cdrom.notImplementedBug = "Ce bogue est déjà enregistré en interne en tant que demande de fonction %1$d.|0A"
msg.cdrom.notImplementedEmpty = " "
msg.cdrom.unlockfail = "Échec du déverrouillage de la porte du lecteur de CD-ROM. L'état du lecteur peut perturber le système d'exploitation invité.|0A"
msg.cdromGeneric.openFailed = "Impossible de se connecter au périphérique '%1$s' : %2$s."
msg.cdromGenericConnect.getlockfail = "Impossible d'obtenir l'état du verrouillage sur le CD-ROM. Lorsque la machine virtuelle est hors tension, le système d'exploitation hôte peut mal interpréter l'état du lecteur."
msg.cdromGenericConnect.lockfail = "Impossible d'acquérir à nouveau le verrou sur le CD-ROM. Le système d'exploitation peut mal interpréter l'état du lecteur.|0A"
msg.cdromImage.cantOpen = "Impossible de connecter le fichier « %1$s » en tant qu'image de CD-ROM : %2$s|0A"
msg.cdromImage.disconnect = "Échec de l'opération sur le fichier image du CD-ROM %1$s. Les opérations ultérieures sur ce fichier échoueront aussi probablement, sauf si vous adoptez des mesures correctives sur la connexion du fichier image. Essayez de déconnecter le fichier image et de le reconnecter ensuite au lecteur de CD-ROM de la machine virtuelle. Sélectionnez %2$s pour poursuivre la transmission de l'erreur au système d'exploitation client. Sélectionnez %3$s pour déconnecter le fichier image.|0A"
msg.cdromImage.needLargeFS = "La taille de fichier « %1$s » n'a pas pu être déterminée correctement La taille de fichier est probablement supérieure à 2 Go et dépasse la taille limite de son système de fichiers.|0APour plus d'informations, consultez la base de connaissances %2$s.|0A"
msg.cdromImage.sigFailed = "La signature d'image ISO n'a pas pu être vérifiée. La vérification de la signature a échoué pour le fichier image ISO « %1$s ». Vérifiez que le fichier image n'est pas endommagé et que des fichiers de signature valides sont présents. Si vous êtes toujours en train de copier cette image, attendez que l'opération soit terminée avant de connecter l'image.|0A"
msg.cdromImage.sizeChanged = "La taille de votre image ISO change. La taille du fichier image ISO |22%1$s|22 est passée de %2$I64u à %3$I64u octets. Si la copie de cette image est toujours en cours, attendez qu'elle soit terminée avant de connecter l'image.|0A"
msg.cdromImage.tooLargeIso = "La taille de votre image ISO est trop importante. Le fichier image ISO |22%1$s|22 dépasse 4 Go, mais seuls 4 Go sont accessibles. Le problème provient probablement d'un serveur de fichiers distant. Pour contourner ce problème, utilisez une image ISO locale.|0APour plus d'informations, consultez la base de connaissances %2$s.|0A"
msg.cdromdisconnect.locked = "Le système d'exploitation client a verrouillé la porte du CD-ROM et utilise probablement ce dernier, ce qui peut empêcher le client de reconnaître les changements de médias. Si possible, éjectez le CD-ROM du client avant la déconnexion.|0A|0ADéconnecter tout de même et ignorer le verrou ?|0A"
msg.cdromdisconnect.locked.darwin = "Cette opération ne peut pas se poursuivre, car votre client Mac OS utilise le CD/DVD.|0A|0AFermez ce message, éjectez le disque à partir du client et réessayez cette opération."
msg.cdromlib.couldntProcess = "Impossible de traiter le lecteur de CD-ROM '%1$s' : %2$s."
