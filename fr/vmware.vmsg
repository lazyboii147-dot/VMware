msg.disk.policyChangeFailure = "Échec de modification de la stratégie de stockage : %1$s."
msg.disk.policyChangeNonpersistent = "Les modifications de la stratégie de stockage ne peuvent pas être appliquées sur des disques non persistants pendant l'exécution de la machine virtuelle."
msg.disk.powerOff.syncing = "Synchronisation du disque '%1$s' pour désactivation."
msg.disk.rawacpi = "Si vous effectuez un double démarrage d'une installation Windows native, des problèmes peuvent se produire lorsque vous essayez de démarrer votre système dans %1$s. Pour plus d'informations, consultez |22%2$s|22.|0ASélectionnez %3$s pour continuer, %4$s pour mettre hors tension.|0A"
msg.disk.rdonlyNeedsRepair = "Le disque '%1$s' comporte des incohérences internes qu'il est nécessaire de résoudre avant de pouvoir l'utiliser. Vous ne disposez pas de droits d'accès en écriture sur le disque virtuel et %2$s ne peut pas réparer le disque. Contactez votre administrateur système pour obtenir de l'aide."
msg.disk.redo.unlinkError = "Échec de la suppression du disque non persistant, '%1$s': %2$s.|0A"
msg.disk.redoLogPersistent = "Un fichier redo-log pour le disque '%1$s' a été trouvé, mais le disque est marqué comme %2$s.|0ASélectionnez une action pour le fichier redo-log.|0A"
msg.disk.redologdirstat = "Impossible d'obtenir des informations pour le répertoire du fichier redo-log %1$s : %2$s.|0A"
msg.disk.scaryWithLostSectors = "Le disque « %1$s » comporte des incohérences internes probablement dues à l'endommagement du fichier de disque. Il est vivement recommandé de restaurer une copie de sauvegarde de cette machine virtuelle, car les données du client sont peut-être également endommagées. Cela peut provoquer une instabilité et un comportement inattendu de l'invité. Si vous ne disposez d'aucune copie de sauvegarde, %2$s peut réparer le disque afin que le client puisse essayer de démarrer à partir de ce dernier. Cependant, il est recommandé de tenter de sauvegarder vos données et de les déplacer vers une machine virtuelle différente ou nouvelle. Si vous envisagez d'effectuer une réparation, %3$I64d secteurs de données seront perdus et %4$I64d secteurs seront peut-être perdus lors du processus de récupération.|0ASouhaitez-vous réparer le disque et continuer ?"
msg.disk.scaryWithNoLostSectors = "Le disque '%1$s' comporte des incohérences internes probablement dues à un endommagement partiel du fichier de disque. Il est recommandé de restaurer une sauvegarde de cette machine virtuelle. Si vous ne disposez d'aucune copie de sauvegarde, %2$s peut réparer le disque. Toutefois, il est possible que les données contenues dans le disque soient endommagées et affectent la stabilité du client.|0ASouhaitez-vous réparer le disque et continuer ?"
