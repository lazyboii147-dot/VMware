msg.vmx.ticket.enable = "Les connexions « %1$s » avec ticket sont désactivées pour cette machine virtuelle."
msg.vmx.ticket.unknown = "Le type de ticket demandé « %1$s » est inconnu."
msg.vmx.tooManyCPUsInWS = "Cette machine virtuelle est configurée pour fonctionner avec %1$u unités centrales, mais %2$s ne peut prendre en charge que %3$u UC. La machine virtuelle ne peut être activée.|0A"
msg.vmx.tooManyVCPUs = "Les machines virtuelles possédant plus de %1$d UC ne sont pas prises en charge. Cette machine virtuelle ne peut pas être activée car elle est configurée pour être exécutée avec %2$d UC.|0A"
msg.vmx.ulm.unsupported = "Votre hôte ne répond pas aux exigences minimales pour exécuter %1$s avec Hyper-V ou Device/Credential Guard activé. Pour plus d'informations, reportez-vous à l'article 76918 de la base de connaissances VMware à l'adresse https://kb.vmware.com/kb/76918."
msg.vmx.vbsRunningDetected = "%1$s et Device/Credential Guard ne sont pas compatibles. Vous pouvez exécuter %2$s après avoir désactivé Device/Credential Guard. Pour plus d'informations, consultez http://www.vmware.com/go/turnoff_CG_DG."
msg.vmxaiomgr.corrupted = "%1$s ne peut synchroniser avec le disque avant l'annulation. Le disque %2$s peut présenter des incohérences.|0A"
msg.vmxaiomgr.retryabort.diskfull = "Échec de l'opération sur le fichier « %1$s » (%2$s).|0ALe système de fichiers où réside le disque « %3$s » est saturé.|0AChoisissez %4$s pour recommencer l'opération.|0AChoisissez %5$s pour terminer la session.|0A"
msg.vmxaiomgr.retrycontabort.diskoverwrite = "Échec de l'opération sur le fichier |22%1$s|22 (%2$s).|0ALe système de fichiers dans lequel réside le disque |22%3$s|22 ne dispose pas de suffisamment d'espace (%4$l64u octets) pour répondre à la demande d'écriture du système d'exploitation invité (%5$l64u octets). Vous pouvez libérer de l'espace sur le système de fichiers et réessayer l'opération.|0ASélectionnez %6$s pour réessayer l'opération.|0ASélectionnez %7$s pour mettre la machine virtuelle hors tension.|0ASélectionnez %8$s pour transmettre l'erreur au système d'exploitation invité."
msg.vmxaiomgr.retrycontabort.rudeunplug = "Échec de l'opération sur le fichier « %1$s ».|0ASi le fichier réside dans un système de fichiers distant, assurez-vous que la connexion réseau et le serveur sur lequel le disque réside fonctionnent correctement. Si le fichier réside sur un support amovible, reconnectez-le.|0AChoisissez %2$s pour tenter de relancer l'opération.|0ASélectionnez %3$s pour mettre fin à la session.|0ASélectionnez %4$s pour transmettre l'erreur au système d'exploitation client."
msg.vmxlsilogic.poweronFailed = "Échec de la configuration de '%1$s'.|0A"
msg.vmxlsilogic.suspendOnUnknownFunction = "Le client a tenté d'émettre une requête inconnue 0x%1$02X vers l'adaptateur LSI. La machine virtuelle doit être désactivée. Veuillez enregistrer le bogue et fournir cette machine virtuelle interrompue et le détail des opérations exécutées au moment de l'incident.|0A|0ASi vous émettez simplement des commandes aléatoires vers l'adaptateur pour vérifier son comportement, ajoutez lsilogic.suspendOnUnknownFunction= « FALSE » au fichier de configuration de la machine virtuelle (cette option est définie sur FALSE par défaut dans les versions disponibles).|0A"
msg.vmxnet.invalidVnetParameter = "Échec de l'activation en raison d'une valeur incorrecte dans le paramètre VNET %1$s.|0A"
msg.vmxvmdb.cpuhotplug = "Impossible d'initier l'enfichage à chaud de l'unité centrale.|0A"
msg.vmxvmdb.devhotadd = "Impossible d'ajouter le périphérique %1$s.|0A"
