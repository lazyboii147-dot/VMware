msg.hostWin32.affinityFailed = "Échec de l'attribution de cette instance de %1$s aux processeurs désirés (%2$s). Tous les processeurs seront utilisés à la place.|0A"
msg.hostWin32.noLegalProcessors = "Vous avez spécifié qu'aucun processeur n'était disponible pour cette machine virtuelle. La configuration de votre processeur sera ignorée et tous les processeurs seront utilisés à la place.|0A"
msg.hostonly.badservice = "La prise en charge de l'hôte uniquement ne semble pas être installée. Le Gestionnaire de contrôle de service signale l'erreur %1$s lors de l'ouverture du service %2$s. Avez-vous installé l'adaptateur réseau Hôte uniquement via le panneau de configuration du réseau ?|0A"
msg.hostonly.noscm = "Avertissement : impossible de se connecter au Gestionnaire de contrôle de service pour vérifier si la prise en charge de l'adaptateur Hôte uniquement est en cours d'exécution. En supposant que tout fonctionne.|0A"
msg.hostonly.noservice = "La prise en charge de l'hôte uniquement ne semble pas être installée. Le Gestionnaire de contrôle de service signale que le service %1$s n'existe pas. Avez-vous installé l'adaptateur réseau Hôte uniquement via le panneau de configuration du réseau ?|0A"
msg.hostonly.servicedown = "Le pilote de l'adaptateur d'hôte uniquement ne semble pas être en cours d'exécution. Si vous n'avez pas redémarré l'hôte depuis l'installation de l'adaptateur réseau Hôte uniquement, vous devez le faire pour pouvoir utiliser cette prise en charge. Sinon, consultez le journal des événements système pour savoir pourquoi le service %1$s n'a pas correctement démarré.|0A"
msg.hostw32.wrongNTversion = "Vous exécutez Windows version %1$d, qui n'est pas un système d'exploitation hôte pris en charge.|0ACe produit est uniquement pris en charge sur Windows 8, Windows 8.1, Windows 10, Windows Server 2012, Windows Server 2016 et Windows Server 2019.|0A"
