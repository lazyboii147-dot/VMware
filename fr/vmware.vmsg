msg.hvuser.NoSVM = "Cet hôte ne prend pas en charge la technologie AMD-V."
msg.hvuser.NoVT = "Cet hôte ne prend pas en charge la technologie Intel VT-x."
msg.hvuser.SVMConfig = "La configuration de cette machine virtuelle ne prend pas en charge les opérations AMD-V."
msg.hvuser.SVMDisabled = "Cet hôte prend en charge AMD-V, mais AMD-V est désactivé.|0AAMD-V peut être désactivé s'il a été désactivé dans les réglages du BIOS/firmware ou l'hôte n'a pas été redémarré depuis la modification de ce réglage.|0A(1) Vérifiez que les réglages du BIOS/firmware autorisent AMD-V.|0A(2) Désactivez, puis réactivez l'hôte si ce réglage du BIOS/firmware a été modifié.|0A(3) Désactivez, puis réactivez l'hôte si vous ne l'avez pas fait depuis l'installation de %1$s.|0A(4) Mettez à jour le BIOS/firmware de l'hôte avec la dernière version."
msg.hvuser.SVMUnsupported = "Cet hôte prend en charge AMD-V, mais l'implémentation d'AMD-V n'est pas compatible avec %1$s."
msg.hvuser.VTConfig = "La configuration de cette machine virtuelle ne prend pas en charge les opérations Intel VT-x."
msg.hvuser.VTDisabled = "Cet hôte prend en charge Intel VT-x, mais Intel VT-x est désactivé.|0AIntel VT-x peut être désactivé s'il a été désactivé dans les réglages du BIOS/firmware ou l'hôte n'a pas été redémarré depuis la modification de ce réglage.|0A(1) Vérifiez que les réglages du BIOS/firmware autorisent Intel VT-x et désactivez « l'exécution fiable ».|0A(2) Désactivez, puis réactivez l'hôte si l'un de ces réglages du BIOS/firmware ont été modifiés.|0A(3) Désactivez, puis réactivez l'hôte si vous ne l'avez pas fait depuis l'installation de %1$s.|0A(4) Mettez à jour le BIOS/firmware de l'hôte avec la dernière version."
msg.hvuser.VTRestricted = "Cet hôte prend en charge Intel VT-x, mais Intel VT-x est restreint.|0AIntel VT-x peut être restreint car « l'exécution fiable » a été activée dans les réglages du BIOS/firmware ou car l'hôte n'a pas été redémarré depuis la modification de ce réglage.|0A(1) Vérifiez que les réglages du BIOS/firmware autorisent Intel VT-x et désactivez « l'exécution fiable ».|0A(2) Désactivez, puis réactivez l'hôte si l'un de ces réglages du BIOS/firmware ont été modifiés.|0A(3) Désactivez, puis réactivez l'hôte si vous ne l'avez pas fait depuis l'installation de %1$s.|0A(4) Mettez à jour le BIOS/firmware de l'hôte avec la dernière version."
msg.hvuser.VTUnlocked = "Cet hôte prend en charge Intel VT-x, mais Intel VT-x n'est pas verrouillé.|0AIl se peut que le BIOS/firmware ait besoin d'une mise à jour.|0A(1) Vérifiez que les réglages du BIOS/firmware autorisent Intel VT-x et désactivez « l'exécution fiable ».|0A(2) Désactivez, puis réactivez l'hôte si l'un de ces réglages du BIOS/firmware ont été modifiés.|0A(3) Désactivez, puis réactivez l'hôte si vous ne l'avez pas fait depuis l'installation de %1$s.|0A(4) Mettez à jour le BIOS/firmware de l'hôte avec la dernière version."
msg.hvuser.VTUnsupported = "Cet hôte prend en charge Intel VT-x, mais l'implémentation d'Intel VT-x n'est pas compatible avec %1$s."
