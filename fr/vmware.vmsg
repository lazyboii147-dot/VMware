msg.guestVarCtl.cfgLimitExceeded = "Les configurations de contrôle d'accès à GuestVariable ont dépassé la limite (%1$u)."
msg.guestos.backward = "Dans la version du logiciel %1$s qui a créé la configuration, le réglage du système d'exploitation client n'était que facultatif. Dans cette version, le réglage est obligatoire pour les performances et l'exactitude.|0AVotre configuration définit la variable `hint.guestOS' en tant que `%2$s'. Assurez-vous que cette valeur reflète le système d'exploitation client exécuté.|0ASélectionnez %3$s pour mettre le fichier de configuration à niveau. Vous devrez enregistrer le fichier ultérieurement.|0ASélectionnez %4$s pour continuer sans la mise à niveau.|0A"
msg.guestos.badArch = "Cette machine virtuelle ne peut pas être activée, car elle nécessite l'architecture de machine %1$s, qui est incompatible avec cet hôte d'architecture de machine %2$s. Consultez l'article 84273 de la base de connaissances.|0A"
msg.guestos.badname = "Le système d'exploitation invité « %1$s » n'est pas pris en charge.|0ASélectionnez-en un à la page %2$s de l'onglet %3$s des paramètres de la machine virtuelle.|0A"
msg.guestos.bootcamp = "Vous utilisez la partition Boot Camp avec %1$s pour la première fois.|0ACette fois seulement, Microsoft Windows mettra jusqu'à une minute pour découvrir la souris et autre matériel virtuel. |0A|0ASur certains systèmes, il est possible que la souris ne soit pas détectée lors du démarrage initial. Pour activer la souris, arrêtez et redémarrez la machine virtuelle.|0A|0AVous serez peut-être invité(e) à réactiver Windows. Pour des résultats optimaux, installez %2$s avant la réactivation.|0A|0APour installer %3$s, patientez jusqu'au démarrage de Windows, puis choisissez %4$s > %5$s et suivez les instructions.|0A"
msg.guestos.noname = "Le fichier de configuration ne spécifie pas de système d'exploitation invité.|0ASélectionnez un système d'exploitation invité sur la page %1$s sous l'onglet %2$s des paramètres de la machine virtuelle.|0A"
msg.gui.cannotReconnect = "Impossible de se connecter au périphérique. %1$s est configuré en tant que périphérique client pour cette machine virtuelle. Vous devez le reconnecter manuellement.|0A"
msg.gui.cannotchangedir = "Impossible de modifier le répertoire à %1$s : %2$s|0A"
msg.gui.noTools = "Aucun paquet %1$s n'est disponible. Désolé, le paquet %2$s n'est pas disponible pour ce système d'exploitation client.|0A"
msg.gui.noToolsForOther = "Aucun paquet %1$s n'est disponible. Désolé, le paquet %2$s n'est pas disponible pour le système d'exploitation client « %3$s ». Vérifiez de nouveau les réglages de la machine virtuelle pour vous assurer que le système d'exploitation client exécuté figure dans la liste.|0A"
