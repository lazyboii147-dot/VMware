msg.vmxvmdbCb.startInstallTools.other = "%1$s va maintenant associer l'image du CD-ROM de VMware Tools à votre machine virtuelle.|0A|0APour installer VMware Tools, connectez-vous à votre client et montez le lecteur de CD-ROM. Consultez la documentation produit de %2$s pour obtenir les étapes d'installation de VMware Tools pour votre système d'exploitation client."
msg.vmxvmdbCb.startInstallTools.windows = "%1$s va maintenant associer l'image du CD-ROM de VMware Tools à votre machine virtuelle.|0A|0ASi vous êtes connecté(e) à votre client mais ne voyez pas l'installation de VMware Tools démarrer, ouvrez le lecteur de CD-ROM sur le client à l'aide de l'Explorateur Windows et double-cliquez sur « setup.exe »."
