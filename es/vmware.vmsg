msg.cdrom.lockfail = "Otro proceso está leyendo el CD-ROM. Hay dos causas posibles: tener habilitada la ejecución automática o tener el CD-ROM abierto en el Explorador de Windows. Esto puede provocar problemas al leer el CD-ROM en la máquina virtual. Deberá hacer que el otro proceso detenga la lectura del CD-ROM antes de permitir que la máquina virtual lea el CD-ROM.|0APara hacerlo ahora, seleccione %1$s. Para hacerlo más tarde, seleccione %2$s y vuelva a conectar el CD-ROM cuando esté listo. También puede omitir este error y todos los errores futuros de este tipo seleccionando %3$s.|0A"
msg.cdrom.notImplemented = "Su máquina virtual envió un comando de CD-ROM no compatible con la emulación heredada.|0AEl paquete del comando era: %1$s|0ANo se trata de un error grave, pero puede provocar un fallo en la aplicación que intente acceder al CD-ROM. Intente ejecutar esta máquina virtual sin la emulación heredada."
msg.cdrom.notImplementedBug = "Esto ya se ha archivado internamente como solicitud de función %1$d.|0A"
msg.cdrom.notImplementedEmpty = " "
msg.cdrom.unlockfail = "No se pudo desbloquear la puerta de la unidad de CD-ROM. El sistema operativo invitado puede estar confuso sobre el estado de la unidad.|0A"
msg.cdromGeneric.openFailed = "Error al conectarse al dispositivo '%1$s': %2$s."
msg.cdromGenericConnect.getlockfail = "No se pudo obtener el estado de bloqueo de la unidad de CD-ROM. Cuando se apague la máquina virtual, es posible que el sistema operativo host interprete de forma incorrecta el estado de la unidad."
msg.cdromGenericConnect.lockfail = "No se ha podido volver a adquirir el bloqueo en el CD-ROM. El sistema operativo invitado puede mal interpretar el estado del controlador.|0A"
msg.cdromImage.cantOpen = "No se puede conectar el archivo |22%1$s|22 a una imagen de CD-ROM: %2$s|0A"
msg.cdromImage.disconnect = "La operación en el archivo de imagen del CD-ROM %1$s ha fallado. Es probable que las operaciones subsiguientes en este archivo también fallen a no ser que la conexión del archivo de imagen se corrija. Intente desconectar el archivo de imagen y, a continuación, intente volver a conectarlo a la unidad del CD-ROM de la máquina virtual. Seleccione %2$s para continuar enviando el error al sistema operativo invitado. Seleccione %3$s para desconectar el archivo de imagen.|0A"
msg.cdromImage.needLargeFS = "El tamaño del archivo de |22%1$s|22 no se pudo determinar correctamente. El tamaño del archivo es superior a 2 GB y supera los límites de tamaño de su sistema de archivos.|0APara obtener más información, consulte la %2$s Base de conocimientos.|0A"
msg.cdromImage.sigFailed = "La firma de la imagen ISO no se puede verificar. Se ha producido un error en la verificación de la firma para el archivo de imagen ISO '%1$s'. Asegúrese de que el archivo de imagen no esté dañado y que incluya archivos de firma válidos. Si sigue copiando esta imagen, espere hasta que la copia se complete antes de conectarla.|0A"
msg.cdromImage.sizeChanged = "El tamaño de la imagen ISO está cambiando. El tamaño del archivo de imagen ISO |22%1$s|22 ha cambiado de %2$I64u a %3$I64u bytes. Si todavía está copiando esta imagen, espere hasta que finalice la copia antes de conectar la imagen.|0A"
msg.cdromImage.tooLargeIso = "El tamaño de la imagen ISO es demasiado grande. El archivo de imagen ISO |22%1$s|22 supera los 4 GB, pero solo se puede acceder a 4 GB. Esto podría ser un problema con un servidor de archivos remoto. Para solucionar este problema, use una imagen ISO local.|0APara obtener más información, consulte la Base de conocimientos de %2$s.|0A"
msg.cdromdisconnect.locked = "El sistema operativo invitado ha bloqueado la puerta del CD-ROM y probablemente utiliza el CD-ROM, lo que puede evitar que el invitado reconozca los cambios de medios. Si es posible, extraiga el CD-ROM de dentro del invitado antes de la desconexión.|0A|0A¿Desea desconectar de todas formas e invalidar el bloqueo?|0A"
msg.cdromdisconnect.locked.darwin = "Esta operación no puede continuar porque su sistema operativo invitado Mac está utilizando el CD/DVD.|0A|0ADescarte este mensaje, extraiga el disco de dentro del invitado y repita la operación."
