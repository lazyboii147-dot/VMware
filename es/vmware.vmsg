msg.hvuser.SVMDisabled = "Este host admite AMD-V, pero AMD-V está desactivado.|0APuede que AMD-V esté desactivado en la configuración del BIOS/firmware o que el host no se haya encendido y apagado desde que se ha cambiado esta configuración.|0A(1) Verifique que la configuración del BIOS/firmware permite AMD-V.|0A(2) Apague y encienda el host si se ha cambiado la configuración del BIOS/firmware.|0A(3) Apague y encienda el host si no lo ha hecho desde la instalación de %1$s.|0A(4) Actualice el BIOS/firmware del host a la versión más reciente."
msg.hvuser.SVMUnsupported = "Este host admite AMD-V, pero la implementación de AMD-V es incompatible con %1$s."
msg.hvuser.VTConfig = "La configuración de esta máquina virtual no es compatible con las operaciones de Intel VT-x."
msg.hvuser.VTDisabled = "Este host admite Intel VT-x, pero Intel VT-x está desactivado.|0APuede que Intel VT-x esté desactivado en la configuración del BIOS/firmware o que el host no se haya encendido y apagado desde que se ha cambiado esta configuración.|0A(1) Verifique que la configuración del BIOS/firmware permite Intel VT-x y desactive la |22ejecución de confianza|22.|0A(2) Apague y encienda el host si se ha cambiado la configuración del BIOS/firmware.|0A(3) Apague y encienda el host si no lo ha hecho desde la instalación de %1$s.|0A(4) Actualice el BIOS/firmware del host a la versión más reciente."
msg.hvuser.VTRestricted = "Este host admite Intel VT-x, pero Intel VT-x está restringido.|0APuede que Intel VT-x esté restringido porque se ha activado la |22ejecución de confianza|22 en la configuración del BIOS/firmware o porque el host no se ha encendido y apagado desde que se ha cambiado esta configuración.|0A(1) Verifique que la configuración del BIOS/firmware permite Intel VT-x y desactive la |22ejecución de confianza|22.|0A(2) Apague y encienda el host si se ha cambiado la configuración del BIOS/firmware.|0A(3) Apague y encienda el host si no lo ha hecho desde la instalación de %1$s.|0A(4) Actualice el BIOS/firmware del host a la versión más reciente."
msg.hvuser.VTUnlocked = "Este host admite Intel VT-x, pero Intel VT-x no está bloqueado.|0APuede que el BIOS/firmware requiera una actualización.|0A(1) Verifique que la configuración del BIOS/firmware permite Intel VT-x y desactive la |22ejecución de confianza|22.|0A(2) Apague y encienda el host si se ha cambiado la configuración del BIOS/firmware.|0A(3) Apague y encienda el host si no lo ha hecho desde la instalación de %1$s.|0A(4) Actualice el BIOS/firmware del host a la versión más reciente."
