msg.vmxaiomgr.retrycontabort.diskoverwrite = "Error de operación en el archivo |22%1$s|22 (%2$s).|0AEl sistema de archivos donde se ubica el disco |22%3$s|22 no tiene suficiente espacio (%4$I64u bytes) para acomodar la solicitud de escritura del sistema operativo invitado (%5$I64u bytes). Puede liberar espacio en el sistema de archivos y repetir la operación.|0ASeleccione %6$s para intentar realizar la operación de nuevo.|0ASeleccione %7$s para apagar la máquina virtual.|0ASeleccione %8$s para enviar el error al sistema operativo invitado."
msg.vmxaiomgr.retrycontabort.rudeunplug = "Error de operación en el archivo |22%1$s|22.|0ASi el archivo reside en un sistema de archivos remoto, asegúrese de que la conexión de red y el servidor donde reside el disco funcionen correctamente. Si el archivo reside en algún medio extraíble, readjunte el medio.|0ASeleccione %2$s para intentar realizar la operación de nuevo.|0ASeleccione %3$s para apagar la máquina virtual.|0ASeleccione %4$s para enviar el error al sistema operativo invitado."
