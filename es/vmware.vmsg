msg.guestOperations.data = "Datos de VIX = (%1$s)."
msg.guestOperations.error = "Códigos de error de VIX = (%1$u, %2$u)."
msg.guestVarCtl.cfgLimitExceeded = "Las configuraciones de control de acceso de GuestVariable superaron el límite (%1$u)."
msg.guestos.backward = "En la versión de software %1$s que ha creado la configuración, la configuración del sistema operativo invitado solo era de asesoramiento. En esta versión, la configuración es necesaria para el rendimiento y la configuración correcta.|0ALa configuración define la variable `hint.guestOS' como `%2$s'. Asegúrese de que este valor refleje el sistema operativo invitado que ejecute.|0ASeleccione %3$s para actualizar el archivo de configuración. Deberá guardar el archivo más adelante.|0ASeleccione %4$s para continuar sin actualizar.|0A"
msg.guestos.badArch = "Esta máquina virtual no se puede encender porque requiere la arquitectura de máquina %1$s, que no es compatible con este host de arquitectura de máquina %2$s. Consulte el artículo 84273 de la base de conocimientos.|0A"
msg.guestos.badname = "No se admite el sistema operativo invitado '%1$s'.|0ASeleccione un sistema operativo invitado de la página %2$s en la pestaña %3$s de configuración de la máquina virtual.|0A"
msg.guestos.bootcamp = "Es la primera vez que utiliza la partición Boot Camp con %1$s.|0ALa primera vez que se use, puede que Microsoft Windows tarde un poco en descubrir el ratón y otro hardware virtual. |0A|0AEn algunos sistemas, puede que el ratón no se detecte en el arranque inicial. Para activar el ratón, desconecte y reinicie la máquina virtual.|0A|0APuede que le pidan que vuelva a activar Windows. Para obtener mejores resultados, instale %2$s antes de volver a activar.|0A|0APara instalar %3$s, espere a que Windows termine de arrancar y, a continuación, seleccione %4$s > %5$s y siga las instrucciones.|0A"
msg.guestos.noname = "El archivo de configuración no especifica un sistema operativo invitado.|0ASeleccione un sistema operativo invitado de la página %1$s en la pestaña %2$s en Configuración de máquina virtual.|0A"
msg.gui.cannotReconnect = "No se puede conectar el dispositivo. Esta máquina virtual tiene %1$s configurado como un dispositivo cliente. Vuelva a conectar el dispositivo manualmente.|0A"
msg.gui.cannotchangedir = "No se puede cambiar directorio a %1$s: %2$s|0A"
msg.gui.noTools = "No hay ningún paquete %1$s disponible. El paquete %2$s no está disponible para este sistema operativo invitado.|0A"
msg.gui.noToolsForOther = "No hay ningún paquete %1$s disponible. El paquete %2$s no está disponible para el sistema operativo invitado |22%3$s|22. Compruebe la configuración de la máquina virtual para asegurarse de que el sistema operativo invitado que está ejecutando esté en la lista.|0A"
msg.gui.toolsNoDevice = "Esta máquina virtual no tiene una unidad %1$s configurada. Una máquina virtual debe tener una unidad %2$s configurada para que esta opción funcione.|0A"
