msg.numa.conflictNumaCPSConfig = "No se puede encender la máquina virtual porque la configuración es incorrecta. Los núcleos por socket deben ser un múltiplo o un divisor del número de núcleos manuales por configuración de NUMA de nodo."
msg.numa.conflictNumaConfig = "No se puede encender la máquina virtual porque la configuración tiene conflictos. Elimine la configuración numa.vcpu.maxPerVirtualNode o los núcleos manuales por configuración de NUMA de nodo."
